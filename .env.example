# Required: HMAC secret for signing JWTs (>= 32 bytes).
# Generate with: openssl rand -hex 32
JWT_SECRET=replace-me-with-a-long-random-secret-of-at-least-32-bytes

# Optional: token lifetime (Go duration). Default: 24h.
JWT_TTL=24h

# Set true behind HTTPS in production (cookie sent only on TLS).
COOKIE_SECURE=false

# PostgreSQL connection string.
#   - Pod deploys (deploy/dev-pod.sh, deploy/deploy.sh): the db + app share one
#     network namespace, so use localhost (the default below). deploy.sh
#     rewrites this from POSTGRES_* on the remote anyway.
#   - docker compose: ignores this and reaches the `db` service by name (the
#     compose file builds its own DSN from POSTGRES_* → @db:5432).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/gnrs?sslmode=disable

# Credentials for the bundled PostgreSQL (postgres:17) container.
# In production deploy.sh generates a random POSTGRES_PASSWORD on first deploy.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=gnrs

# Cloudflare Tunnel token — PRODUCTION ONLY (public access from the
# jalur-yasril deploy). Create the tunnel in the Cloudflare Zero Trust
# dashboard (Networks → Tunnels → Create), point its public hostname at
# http://localhost:8080, and paste the token here. Leave EMPTY for local dev
# pods and for the gnrs-evan track — no public tunnel is created when unset.
CLOUDFLARE_TUNNEL_TOKEN=

# Directory for uploaded photos (PHOTOS_DIR defaults to $DATA_DIR/photos).
# In Docker the compose file pins this to /app/data.
DATA_DIR=./data

# Optional bootstrap admin (seeded only if users table is empty).
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=changeme

# HTTP listen port (default 8080).
PORT=8080

# Set 1 to skip serving the embedded SPA (Vite dev server takes over on :5173).
DEV=0
